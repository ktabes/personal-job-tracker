DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CHANNEL_ID=

# Optional. Set this for fast guild-scoped command registration during personal use.
DISCORD_GUILD_ID=

# Railway volume paths. Mount a Railway volume at /data and keep these defaults.
DATABASE_PATH=/data/job-search-tracker.sqlite
CSV_EXPORT_PATH=/data/applications.csv

# Scheduling is explicitly timezone-aware. Default is the requested Eastern timezone.
REPORT_TIMEZONE=America/New_York
